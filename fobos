[project]
name       = FUNDAL
version    = VERSION
summary    = Fortran UNified Device Acceleration Library
repository = https://github.com/szaghi/FUNDAL
website    = https://szaghi.github.io/FUNDAL
email      = stefano.zaghi@gmail.it
authors    = Stefano Zaghi

# user-tunable variables (FoBiS fobos variables)
[common-variables]
# AMD GPU target architecture(s) for amdflang OpenMP offload.
# Set to match your GPU, e.g. gfx90a, gfx942, gfx1100, or a comma-separated list.
# This is the default value; it can be completely overwritten from the CLI by
# selecting one of the [varset:*] sections below, e.g.
#   FoBiS.py build -mode fundal-test-omp-amd --varset gfx1100
$GPU_ARCH = gfx942

# CLI-selectable GPU architecture overrides.
# Each varset fully replaces $GPU_ARCH (last-write-wins); pick one with --varset.
[varset:gfx906]
$GPU_ARCH = gfx906

[varset:gfx908]
$GPU_ARCH = gfx908

[varset:gfx90a]
$GPU_ARCH = gfx90a

[varset:gfx940]
$GPU_ARCH = gfx940

[varset:gfx942]
$GPU_ARCH = gfx942

[varset:gfx950]
$GPU_ARCH = gfx950

[varset:gfx1030]
$GPU_ARCH = gfx1030

[varset:gfx1100]
$GPU_ARCH = gfx1100

[modes]
modes = fundal-test-nvf
        fundal-test-oac-nvf
        fundal-test-oac-nvf-debug
        fundal-test-oac-mpi-nvf
        fundal-test-oac-mpi-nvf-debug
        fundal-test-gnu
        fundal-test-oac-gnu
        fundal-test-oac-mpi-gnu
        fundal-test-amd
        fundal-test-omp-amd
        fundal-test-omp-mpi-amd
        fundal-test-ifx
        fundal-test-omp-ifx
        fundal-test-omp-mpi-ifx
        fundal-void-nvf
        fundal-void-oac-nvf
        fundal-void-omp-nvf
        fundal-void-gnu
        fundal-void-oac-gnu
        fundal-void-amd
        fundal-void-oac-amd
        fundal-void-ifx

# modes to build library and tests
[fundal-test-nvf]
help          = Build FUNDAL tests with NVF
template      = template-nvf
src           = ./src/
exclude_dirs  = ./src/tests/mpi/

[fundal-test-oac-nvf]
help          = Build FUNDAL tests with OpenACC-NVF
template      = template-oac-nvf
src           = ./src/
exclude_dirs  = ./src/tests/mpi/

[fundal-test-oac-nvf-debug]
help          = Build FUNDAL tests with OpenACC-NVF in debug mode
template      = template-oac-nvf-debug
src           = ./src/
exclude_dirs  = ./src/tests/mpi/

[fundal-test-oac-mpi-nvf]
help     = Build FUNDAL tests with OpenACC-MPI-NVF
template = template-oac-nvf
mpi      = True
src      = ./src/

[fundal-test-oac-mpi-nvf-debug]
help     = Build FUNDAL tests with OpenACC-MPI-NVF in debug mode
template = template-oac-nvf-debug
mpi      = True
src      = ./src/

[fundal-test-gnu]
help          = Build FUNDAL tests with GNU
template      = template-gnu
src           = ./src/
exclude_dirs  = ./src/tests/mpi/

[fundal-test-oac-gnu]
help          = Build FUNDAL tests with OpenACC-GNU
template      = template-oac-gnu
src           = ./src/
exclude_dirs  = ./src/tests/mpi/

[fundal-test-oac-mpi-gnu]
help     = Build FUNDAL tests with OpenACC-MPI-GNU
template = template-oac-gnu
mpi      = True
src      = ./src/

[fundal-test-amd]
help          = Build FUNDAL tests with AMD Flang
template      = template-amd
src           = ./src/
exclude_dirs  = ./src/tests/mpi/

[fundal-test-omp-amd]
help          = Build FUNDAL tests with OpenMP-AMD Flang
template      = template-omp-amd
src           = ./src/
exclude_dirs  = ./src/tests/mpi/

[fundal-test-omp-mpi-amd]
help     = Build FUNDAL tests with OpenMP-MPI-AMD Flang
template = template-omp-amd
mpi      = True
src      = ./src/


[fundal-test-ifx]
help          = Build FUNDAL tests with IFX
template      = template-ifx
src           = ./src/
exclude_dirs  = ./src/tests/mpi/

[fundal-test-omp-ifx]
help          = Build FUNDAL tests with OpenMP-IFX
template      = template-omp-ifx
src           = ./src/
exclude_dirs  = ./src/tests/mpi/

[fundal-test-omp-mpi-ifx]
help     = Build FUNDAL tests with OpenMP-MPI-IFX
template = template-omp-ifx
mpi      = True
src      = ./src/

# void modes to build a specified target/src (-t/-src must be passed by CLI)

[fundal-void-nvf]
help     = Build a specified target/src with NVF (no pragmas)
template = template-nvf

[fundal-void-oac-nvf]
help     = Build a specified target/src with OpenACC-NVF
template = template-oac-nvf

[fundal-void-gnu]
help     = Build a specified target/src with GNU (no pragmas)
template = template-gnu

[fundal-void-oac-gnu]
help     = Build a specified target/src with OpenACC-GNU
template = template-oac-gnu

[fundal-void-amd]
help     = Build a specified target/src with AMD Flang (no pragmas)
template = template-amd

[fundal-void-omp-amd]
help     = Build a specified target/src with OpenMP-AMD Flang
template = template-omp-amd

[fundal-void-ifx]
help     = Build a specified target/src with IFX (no pragmas)
template = template-ifx

[fundal-void-omp-ifx]
help     = Build a specified target/src with OpenMP-IFX
template = template-omp-ifx

# templates

[template-base]
mod_dir   = ./mod/
obj_dir   = ./obj/
build_dir = ./exe/
colors    = True
quiet     = False
log       = True
jobs      = 4

[template-nvf]
template = template-base
compiler = nvfortran
preproc  = -DCOMPILER_NVF
cflags   = -cpp -c -fast -Minfo=all
lflags   = -Minfo=all

[template-oac-nvf]
template = template-base
compiler = nvfortran
preproc  = -DCOMPILER_NVF -DDEV_OAC
cflags   = -cpp -c -acc -gpu=cc89 -fast -Minfo=all
lflags   = -acc -gpu=cc89 -fast -Minfo=all

[template-oac-nvf-debug]
template = template-oac-nvf
cflags   = -cpp -c -acc -gpu=cc89 -Minfo=all -C -g
lflags   = -acc -gpu=cc89 -Minfo=all -C -g

[template-gnu]
template = template-base
compiler = gnu
preproc  = -DCOMPILER_GNU
cflags   = -cpp -c
lflags   = -cpp

[template-oac-gnu]
template = template-base
compiler = gnu
preproc  = -DCOMPILER_GNU -DDEV_OAC
cflags   = -cpp -c -fopenacc
lflags   = -fopenacc

[template-oac-gnu-debug]
template  = template-oac-gnu
cflags    = -cpp -c -fopenacc -g -fcheck=all -fbacktrace
lflags    = -fopenacc -g -fcheck=all -fbacktrace

[template-amd]
template = template-base
compiler  = amd
cflags    = -c -cpp
lflags    = -cpp
openmp    = True

[template-omp-amd]
# DEV_HIP enables the HIP-->Fortran interfaces (device memory status, etc.) and
# links the HIP runtime (libamdhip64). It is set ONLY for AMD builds: the same
# OpenMP-offload backend (DEV_OMP) is also used by Intel IFX, which must NOT link
# HIP libraries (they are not available outside the AMD/ROCm stack).
# NOTE: the HIP runtime is found through the shell environment (LIBRARY_PATH at
# link time, LD_LIBRARY_PATH at run time), which a sourced ROCm environment
# populates from $ROCM_PATH. FoBiS runs the compiler with shell=False and does
# not expand environment variables in flags, so no path is hardcoded here; make
# sure $ROCM_PATH (and the ROCm lib dir) are in your environment before building.
template = template-base
compiler = amd
preproc  = -DDEV_OMP -DDEV_HIP
cflags   = -c -cpp --offload-arch=$GPU_ARCH
lflags   = -cpp --offload-arch=$GPU_ARCH -lamdhip64
openmp   = True

[template-ifx]
template = template-base
compiler = intel_nextgen
cflags   = -c -cpp
lflags   = -cpp
openmp   = True

[template-omp-ifx]
template       = template-base
compiler       = intel_nextgen
preproc        = -DDEV_OMP
cflags         = -c -cpp
lflags         = -cpp
openmp         = True
openmp_offload = True

# aux rules
[rule-run-tests]
help   = Run all tests
rule_1 = scripts/run_tests.sh

[rule-build-run-tests-oac-nvf]
help   = Build and Run all tests with OpenACC-NVF
rule_1 = FoBiS.py clean
rule_2 = FoBiS.py build -mode fundal-test-oac-nvf
rule_3 = FoBiS.py rule -ex run-tests

[rule-build-run-tests-omp-ifx]
help   = Build and Run all tests with OpenMP-IFX
rule_1 = FoBiS.py clean
rule_2 = FoBiS.py build -mode fundal-test-omp-ifx
rule_3 = FoBiS.py rule -ex run-tests

[rule-build-run-tests-oac-gnu]
